<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Học Từ Vựng Unit 1 - MCQ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@400;600;800&display=swap');
        body { font-family: 'Lexend', sans-serif; background-color: #f0f9ff; }
        .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); }
        .correct-anim { animation: celebrate 0.5s ease-out; }
        @keyframes celebrate {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        .image-container { position: relative; width: 256px; height: 192px; margin: 0 auto; }
        #vocab-image { width: 100%; height: 100%; object-fit: cover; border-radius: 1rem; }
        .error-placeholder { 
            position: absolute; inset: 0; display: flex; align-items: center; 
            justify-content: center; background: #f3f4f6; border-radius: 1rem; font-size: 4rem;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-4">

    <div id="game-container" class="w-full max-w-md bg-white rounded-3xl p-6 card-shadow relative overflow-hidden">
        
        <div class="w-full bg-gray-200 rounded-full h-2.5 mb-6">
            <div id="progress-bar" class="bg-blue-500 h-2.5 rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>

        <div class="flex justify-between items-center mb-6">
            <span class="text-blue-600 font-bold uppercase tracking-wider text-sm">Unit 1: Vocabulary</span>
            <span id="question-counter" class="text-gray-500 font-medium text-sm">Câu 1/23</span>
        </div>

        <div id="question-area" class="text-center">
            <div class="image-container group cursor-pointer mb-4" onclick="speak()">
                <div id="img-fallback" class="error-placeholder hidden">❓</div>
                <img id="vocab-image" src="" alt="Vocabulary Image" onerror="handleImageError()">
                <button class="absolute bottom-2 right-2 bg-blue-600 text-white p-3 rounded-full shadow-lg hover:bg-blue-700 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
                    </svg>
                </button>
            </div>
            
            <h2 class="text-xl font-bold text-gray-800 mb-6 italic">"Đố bạn đây là từ gì?"</h2>

            <div id="options-grid" class="grid grid-cols-1 gap-3 mb-6"></div>

            <div id="feedback" class="h-8 mb-4 font-bold text-lg hidden"></div>

            <button id="next-btn" onclick="nextQuestion()" class="w-full bg-green-500 text-white py-4 rounded-xl font-bold shadow-lg hover:bg-green-600 transform transition-all hidden">
                TIẾP THEO ➜
            </button>
        </div>

        <div id="result-screen" class="hidden text-center py-10">
            <div class="text-6xl mb-4">🎉</div>
            <h1 class="text-3xl font-extrabold text-blue-900 mb-2">Tuyệt vời!</h1>
            <p class="text-gray-600 mb-8">Bạn đã hoàn thành 23 từ vựng của Unit 1.</p>
            <button onclick="restartGame()" class="bg-blue-600 text-white px-8 py-3 rounded-full font-bold shadow-lg hover:bg-blue-700">
                Làm lại từ đầu
            </button>
        </div>
    </div>

    <script>
        const vocabulary = [
            { word: 'apple', img: 'https://images.unsplash.com/photo-1560806887-1e4cd0b6bcd6?w=400', emoji: '🍎' },
            { word: 'bus', img: 'https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?w=400', emoji: '🚌' },
            { word: 'cake', img: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=400', emoji: '🍰' },
            { word: 'dog', img: 'https://images.unsplash.com/photo-1517849845537-4d257902454a?w=400', emoji: '🐶' },
            { word: 'elephant', img: 'https://images.unsplash.com/photo-1557050543-4d5f4e07ef46?w=400', emoji: '🐘' },
            { word: 'fish', img: 'https://images.unsplash.com/photo-1524704654690-b56c05c78a00?w=400', emoji: '🐟' },
            { word: 'guitar', img: 'https://images.unsplash.com/photo-1525201548942-d8b8967d0f12?w=400', emoji: '🎸' },
            { word: 'house', img: 'https://images.unsplash.com/photo-1580587771525-78b9dba3b914?w=400', emoji: '🏠' },
            { word: 'insect', img: 'https://images.unsplash.com/photo-1470114755716-3e4299863a1e?w=400', emoji: '🐞' },
            { word: 'jacket', img: 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=400', emoji: '🧥' },
            { word: 'key', img: 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRU3lWI-3G5Tmfk_ZJA-Swj6EgZNqEVIhemQg&s', emoji: '🔑' },
            { word: 'lamp', img: 'https://images.unsplash.com/photo-1507473885765-e6ed057f782c?w=400', emoji: '💡' },
            { word: 'mouse', img: 'https://images.unsplash.com/photo-1425082661705-1834bfd09dca?w=400', emoji: '🐭' },
            { word: 'nose', img: 'https://static.vecteezy.com/system/resources/thumbnails/041/916/132/small/nose-cartoon-illustration-isolated-on-white-background-vector.jpg', emoji: '👃' },
            { word: 'orange', img: 'https://images.unsplash.com/photo-1547514701-42782101795e?w=400', emoji: '🍊' },
            { word: 'pencil', img: 'https://images.unsplash.com/photo-1512036667332-235764f723ef?w=400', emoji: '✏️' },
            { word: 'queen', img: 'https://us.123rf.com/450wm/glebdesign159/glebdesign1592409/glebdesign159240901326/235137438-ilustraci%C3%B3n-de-dibujos-animados-vectoriales-de-la-reina-mujer-real.jpg?ver=6', emoji: '👑' },
            { word: 'ruler', img: 'https://images.unsplash.com/photo-1586075010633-24701bd6e8b7?w=400', emoji: '📏' },
            { word: 'sofa', img: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=400', emoji: '🛋️' },
            { word: 'table', img: 'https://images.unsplash.com/photo-1577140917170-285929fb55b7?w=400', emoji: 'Table' },
            { word: 'umbrella', img: 'https://images.unsplash.com/photo-1520114056694-922117d9d746?w=400', emoji: '☂️' },
            { word: 'van', img: 'https://images.unsplash.com/photo-1565643834241-e946654b4260?w=400', emoji: '🚐' },
            { word: 'window', img: 'https://images.unsplash.com/photo-1503708928276-19620ca99240?w=400', emoji: '🪟' }
        ];

        let currentIndex = 0;
        let canClick = true;

        function shuffle(array) {
            return array.sort(() => Math.random() - 0.5);
        }

        function speak() {
            const utterance = new SpeechSynthesisUtterance(vocabulary[currentIndex].word);
            utterance.lang = 'en-US';
            utterance.rate = 0.8;
            window.speechSynthesis.speak(utterance);
        }

        function handleImageError() {
            const img = document.getElementById('vocab-image');
            const fallback = document.getElementById('img-fallback');
            img.classList.add('hidden');
            fallback.classList.remove('hidden');
            fallback.innerText = vocabulary[currentIndex].emoji;
        }

        function loadQuestion() {
            canClick = true;
            const currentItem = vocabulary[currentIndex];
            
            document.getElementById('question-counter').innerText = `Câu ${currentIndex + 1}/${vocabulary.length}`;
            document.getElementById('progress-bar').style.width = `${((currentIndex + 1) / vocabulary.length) * 100}%`;
            
            const img = document.getElementById('vocab-image');
            const fallback = document.getElementById('img-fallback');
            img.classList.remove('hidden');
            fallback.classList.add('hidden');
            img.src = currentItem.img;
            
            document.getElementById('feedback').classList.add('hidden');
            document.getElementById('next-btn').classList.add('hidden');
            
            let options = [currentItem.word];
            while (options.length < 4) {
                let randomWord = vocabulary[Math.floor(Math.random() * vocabulary.length)].word;
                if (!options.includes(randomWord)) {
                    options.push(randomWord);
                }
            }
            shuffle(options);

            const grid = document.getElementById('options-grid');
            grid.innerHTML = '';
            options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = "w-full py-4 px-6 text-lg font-semibold bg-gray-50 border-2 border-gray-100 rounded-2xl transition-all hover:border-blue-400 hover:bg-blue-50 active:scale-95";
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(opt, btn);
                grid.appendChild(btn);
            });

            setTimeout(speak, 500);
        }

        function checkAnswer(selected, btn) {
            if (!canClick) return;
            
            const correct = vocabulary[currentIndex].word;
            const feedbackEl = document.getElementById('feedback');
            
            if (selected === correct) {
                canClick = false;
                btn.classList.remove('bg-gray-50', 'border-gray-100');
                btn.classList.add('bg-green-100', 'border-green-500', 'text-green-700', 'correct-anim');
                feedbackEl.innerText = "Chính xác! 🌟";
                feedbackEl.className = "h-8 mb-4 font-bold text-lg text-green-600 block";
                
                const s = new SpeechSynthesisUtterance("Correct");
                window.speechSynthesis.speak(s);
                document.getElementById('next-btn').classList.remove('hidden');
            } else {
                btn.classList.add('bg-red-100', 'border-red-500', 'text-red-700');
                feedbackEl.innerText = "Thử lại nhé! ❌";
                feedbackEl.className = "h-8 mb-4 font-bold text-lg text-red-600 block animate-bounce";
                
                const s = new SpeechSynthesisUtterance("Wrong");
                window.speechSynthesis.speak(s);
                
                setTimeout(() => {
                    btn.classList.remove('bg-red-100', 'border-red-500', 'text-red-700');
                }, 800);
            }
        }

        function nextQuestion() {
            if (currentIndex < vocabulary.length - 1) {
                currentIndex++;
                loadQuestion();
            } else {
                document.getElementById('question-area').classList.add('hidden');
                document.getElementById('result-screen').classList.remove('hidden');
            }
        }

        function restartGame() {
            currentIndex = 0;
            document.getElementById('question-area').classList.remove('hidden');
            document.getElementById('result-screen').classList.add('hidden');
            shuffle(vocabulary);
            loadQuestion();
        }

        window.onload = () => {
            shuffle(vocabulary);
            loadQuestion();
        };
    </script>
</body>
</html>
